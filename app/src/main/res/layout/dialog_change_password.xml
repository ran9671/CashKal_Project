<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp">

    <TextView
        style="@style/CashKalTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_change_password"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <!-- current password (needed by Firebase for re-authentication) -->
    <TextView
        style="@style/CashKalLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_current_password" />

    <EditText
        android:id="@+id/et_current_password"
        style="@style/CashKalInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPassword" />

    <!-- new password -->
    <TextView
        style="@style/CashKalLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_new_password" />

    <EditText
        android:id="@+id/et_new_password"
        style="@style/CashKalInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPassword" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btn_pw_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dialog_cancel"
            android:backgroundTint="@color/aqua"
            android:textColor="@color/text_primary"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_pw_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dialog_save"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white" />

    </LinearLayout>

</LinearLayout>