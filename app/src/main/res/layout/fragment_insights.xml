<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            style="@style/CashKalTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_insights"
            android:layout_marginBottom="16dp" />

        <!-- toggle: expenses / incomes, pinned to the right -->
        <RadioGroup
            android:id="@+id/rg_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="end"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rb_expenses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="הוצאות"
                android:checked="true"
                android:layout_marginEnd="24dp" />

            <RadioButton
                android:id="@+id/rb_incomes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="הכנסות" />

        </RadioGroup>

        <!-- balance-left card -->
        <LinearLayout
            style="@style/CashKalCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="נשאר מהמאזן החודש"
                android:textColor="@color/muted_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_balance_left"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- top category card -->
        <LinearLayout
            style="@style/CashKalCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_top_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="הקטגוריה הגבוהה החודש"
                android:textColor="@color/muted_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_top_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_top_category_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="מצטבר לפי קטגוריה"
            android:textColor="@color/muted_text"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/line_chart"
            android:layout_width="match_parent"
            android:layout_height="260dp" />

    </LinearLayout>

</ScrollView>