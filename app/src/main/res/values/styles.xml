<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- primary button -->
    <style name="CashKalButton">
        <item name="android:background">@drawable/bg_button_rounded</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- rounded input field -->
    <style name="CashKalInput">
        <item name="android:background">@drawable/bg_input_rounded</item>
        <item name="android:padding">16dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/muted_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- white rounded card container -->
    <style name="CashKalCard">
        <item name="android:background">@drawable/bg_card_rounded</item>
        <item name="android:padding">22dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:elevation">1dp</item>
    </style>

    <!-- small muted field label -->
    <style name="CashKalLabel">
        <item name="android:textColor">@color/muted_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <!-- large bold section title -->
    <style name="CashKalTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

</resources>